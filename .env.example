# Supabase — ขอจาก A (ค่าเดียวกันทั้งทีม)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key — bypass RLS ได้ทั้งฐานข้อมูล
# A ถือคนเดียว ใช้เฉพาะ npm run seed / verify:* เท่านั้น
# ไม่มีก็รันแอปได้ปกติ (ยกเว้นปุ่ม "ลบบัญชี" ซึ่ง A ตรวจบน production ให้)
SUPABASE_SERVICE_ROLE_KEY=

# Gemini — ใช้ key/โปรเจกต์ของตัวเอง ห้ามแชร์
# โควตาฟรีนับต่อ "โปรเจกต์ × โมเดล" (ไม่ใช่ต่อ key) — โมเดลที่ pin ไว้ (gemini-3.1-flash-lite) = 500 ครั้ง/วัน
# ขอฟรีที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=

# AI_MODEL — ห้ามตั้งไว้ถาวร! โมเดล production ล็อกที่ src/lib/ai/model.ts (DEFAULT_MODEL) แล้ว
# ตัวแปรนี้มีไว้ override ชั่วคราวเวลาลองโมเดลอื่นบนเครื่องตัวเองเท่านั้น
# ตั้งค้างไว้ = รันคนละโมเดลกับ production เงียบ ๆ (เคยทำหลักฐาน safety เสียมาแล้ว 2 รอบ — ดู INFRA-23)
# AI_MODEL=

# บัญชี demo (ใส่เฉพาะเวลาจะรัน seed — ปกติไม่ต้อง)
# DEMO_EMAIL=palm@example.com
# DEMO_PASSWORD=PalmDemo2026!
