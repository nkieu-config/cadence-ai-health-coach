{
  "name": "healthcoach",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ai": "node --env-file=.env.local --import tsx scripts/test-ai.ts",
    "test:insight": "node --env-file=.env.local --import tsx scripts/test-insight.ts",
    "test:coach": "node --env-file=.env.local --import tsx scripts/test-coach-context.ts",
    "verify:db": "node --env-file=.env.local --import tsx scripts/verify-db.ts",
    "verify:user": "node --env-file=.env.local --import tsx scripts/verify-user.ts",
    "seed": "node --env-file=.env.local --import tsx scripts/seed.ts",
    "verify:seed": "node --env-file=.env.local --import tsx scripts/verify-seed.ts",
    "verify:rls": "node --env-file=.env.local --import tsx scripts/verify-rls.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@google/genai": "^2.10.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
